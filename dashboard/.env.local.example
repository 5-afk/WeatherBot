# Copy to dashboard/.env.local — restart `pnpm dev` after edits.
# VITE_API_URL = Flask proxy target (Tailscale/LAN). Browser always calls relative /api/*.
# ThinkPad: run `tailscale ip -4` on the bot host (e.g. ideapad → 100.111.100.108)
VITE_API_URL=http://100.111.100.108:5000
# Must match DASHBOARD_SECRET in project .env on the ThinkPad
VITE_DASHBOARD_SECRET=atlas2026
