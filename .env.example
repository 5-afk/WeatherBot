# Kalshi
KALSHI_API_KEY=your_key_here
KALSHI_API_SECRET=your_secret_here
KALSHI_ENV=demo
KALSHI_API_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Discord
DISCORD_BOT_TOKEN=your_token_here
DISCORD_CHANNEL_ID=your_channel_id_here
# Discord user ID to ping on trades (right click your name → Copy User ID)
DISCORD_USER_ID=your_discord_user_id_here

# Bot settings
DRY_RUN=true
DAILY_BUDGET=300
REINVEST_PCT=0.75
LOG_LEVEL=INFO

# Risk controls
MAX_BET_USD=75
MAX_BET_PCT=1.0
MAX_OPEN_POSITIONS=4
DAILY_LOSS_LIMIT=225
MONTHLY_LOSS_LIMIT=500
MAX_DRAWDOWN_PCT=0.40
STARTING_BALANCE=100
KELLY_FRACTION=0.15
MIN_EDGE=0.08
MIN_EV_PER_CONTRACT=0.05
NO_SIDE_BIAS=1.15
MIN_CONFIDENCE=0.60
MAX_CLAUDE_CALLS_PER_DAY=5
MIN_CONTRACT_PRICE=0.30
MAX_CONTRACT_PRICE=0.85
DENVER_MIN_EDGE=0.15
MIN_LIQUIDITY_CONTRACTS=10
MIN_LIQUIDITY_NEW_CITY=10
SETTLEMENT_WINDOW_HOURS=36

# Weather settings
# Forecast source: NWS gridded hourly API (free, unlimited). Probability via normal CDF.
NWS_USER_AGENT=kalshi-weather-bot/1.0 your-email@example.com
NWS_SUMMER_HIGH_WARM_BIAS_F=1.5
NWS_SUMMER_LOW_BIAS_F=1.0
NWS_FORECAST_CACHE_TTL_MINUTES=60
NWS_FORECAST_SIGMA_F=3.5
CITY_COUNT=13
SCAN_INTERVAL_MINUTES=30
MAX_SCAN_WORKERS=10
RUN_ON_START=true
