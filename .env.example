# Kalshi
KALSHI_API_KEY=your_key_here
KALSHI_API_SECRET=your_secret_here
KALSHI_ENV=demo
KALSHI_API_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Discord
DISCORD_BOT_TOKEN=your_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Bot settings
DRY_RUN=true
DAILY_BUDGET=100
REINVEST_PCT=0.6
LOG_LEVEL=INFO

# Risk controls
MAX_BET_USD=20
MAX_BET_PCT=0.05
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT=20
MONTHLY_LOSS_LIMIT=60
MAX_DRAWDOWN_PCT=0.40
STARTING_BALANCE=1000
KELLY_FRACTION=0.15
MIN_EDGE=0.10
MIN_CONFIDENCE=0.70
MIN_CONTRACT_PRICE=0.15
MAX_CONTRACT_PRICE=0.85
SETTLEMENT_WINDOW_HOURS=24

# Weather settings
NWS_USER_AGENT=kalshi-weather-bot/1.0 your-email@example.com
NWS_SUMMER_HIGH_WARM_BIAS_F=1.5
SCAN_INTERVAL_MINUTES=30
RUN_ON_START=true
